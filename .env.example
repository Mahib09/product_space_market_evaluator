# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Required
OPENAI_API_KEY=sk-your-key-here

# Optional model overrides
# OPENAI_MODEL_SEARCH=gpt-4.1
# OPENAI_MODEL_EXTRACT=gpt-5

# Debug
# DEBUG_WEB_SEARCH_SHAPE=false

# Enable Agent 3 follow-up search when TAM+CAGR are both null (adds 60-120s)
# AGENT3_FOLLOWUP=false
